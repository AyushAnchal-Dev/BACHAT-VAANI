# Example environment variables for BachatKhata
# Copy this file to `.env` and fill real values locally (DO NOT commit `.env`).

# Required: PostgreSQL connection string (Neon, Supabase, or self-hosted)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require&schema=bachatvaani
DATABASE_URL=

# Required: strong secret for signing JWTs and session cookies (min 32 chars)
JWT_SECRET=

# Optional: runtime environment
NODE_ENV=development

# Optional: comma-separated list of allowed origins for production (no wildcards)
# Example: https://app.example.com,https://www.example.com
ALLOWED_ORIGINS=

# Optional: external services (leave empty if unused)
# CLOUDINARY_URL= (or CLOUDINARY_CLOUD_NAME + CLOUDINARY_API_KEY + CLOUDINARY_API_SECRET)
